---
import { Image } from "astro:assets";

import aosiFlyer from "../assets/projects/aosi_flyer_01.jpg";
import aosiLogo from "../assets/projects/aosi_logo_01.jpg";
import floraFlyer1 from "../assets/projects/dinujaya_flora_flyer_design_01.jpg";
import floraFlyer2 from "../assets/projects/dinujaya_flora_flyer_design_02.jpg";
---

<section id="portfolio" class="py-28 bg-gray-50/50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-3xl mb-20">
      <h2 class="text-4xl font-extrabold text-dark mb-4 tracking-tight">
        Creative & Brand Identity
      </h2>
      <p class="text-xl text-gray-600 leading-relaxed">
        A curated showcase of premium brand identities, marketing materials, and
        visual designs crafted for actual clients.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div
        class="group bg-white rounded-3xl overflow-hidden border border-gray-100 shadow-[0_4px_30px_rgba(0,0,0,0.02)] hover:shadow-[0_30px_60px_rgba(15,98,254,0.08)] transition-all duration-500 hover:-translate-y-2"
      >
        <a
          data-fslightbox="gallery"
          href={aosiFlyer.src}
          class="block aspect-[4/3] bg-gray-100 w-full relative overflow-hidden flex items-center justify-center p-6 cursor-zoom-in"
        >
          <Image
            src={aosiFlyer}
            alt="Aosi Brand Campaign Flyer Design by Logic Lanka"
            class="w-full h-full object-contain transition-transform duration-700 ease-out group-hover:scale-105"
            quality="high"
          />
        </a>
        <div class="p-8 md:p-10">
          <div class="flex flex-wrap gap-2 mb-4">
            <span
              class="px-3 py-1 text-xs font-bold text-primary bg-blue-50 rounded-full"
              >Print Media</span
            >
          </div>
          <h3 class="text-2xl font-bold text-dark mb-3">Aosi Brand Campaign</h3>
          <p class="text-gray-600 text-sm">
            Clean, high-converting flyer design focused on clear typography.
          </p>
        </div>
      </div>

      <div
        class="group bg-white rounded-3xl overflow-hidden border border-gray-100 shadow-[0_4px_30px_rgba(0,0,0,0.02)] hover:shadow-[0_30px_60px_rgba(15,98,254,0.08)] transition-all duration-500 hover:-translate-y-2"
      >
        <a
          data-fslightbox="gallery"
          href={floraFlyer1.src}
          class="block aspect-[4/3] bg-gray-100 w-full relative overflow-hidden flex items-center justify-center p-6 cursor-zoom-in"
        >
          <Image
            src={floraFlyer1}
            alt="Dinujaya Flora Premium Wedding Decor Branding Sri Lanka"
            class="w-full h-full object-contain transition-transform duration-700 ease-out group-hover:scale-105"
            quality="high"
          />
        </a>
        <div class="p-8 md:p-10">
          <div class="flex flex-wrap gap-2 mb-4">
            <span
              class="px-3 py-1 text-xs font-bold text-emerald-600 bg-emerald-50 rounded-full"
              >Brand Identity</span
            >
          </div>
          <h3 class="text-2xl font-bold text-dark mb-3">
            Dinujaya Flora Branding
          </h3>
          <p class="text-gray-600 text-sm">
            Elegant visual identity crafted to reflect premium floral services.
          </p>
        </div>
      </div>

      <div
        class="group bg-white rounded-3xl overflow-hidden border border-gray-100 shadow-[0_4px_30px_rgba(0,0,0,0.02)] hover:shadow-[0_30px_60px_rgba(15,98,254,0.08)] transition-all duration-500 hover:-translate-y-2"
      >
        <a
          data-fslightbox="gallery"
          href={aosiLogo.src}
          class="block aspect-[4/3] bg-gray-100 w-full relative overflow-hidden flex items-center justify-center p-8 cursor-zoom-in"
        >
          <Image
            src={aosiLogo}
            alt="Aosi Modern Logo Design and Vector Art"
            class="w-full h-full object-contain transition-transform duration-700 ease-out group-hover:scale-105"
            quality="high"
          />
        </a>
        <div class="p-8 md:p-10">
          <div class="flex flex-wrap gap-2 mb-4">
            <span
              class="px-3 py-1 text-xs font-bold text-purple-600 bg-purple-50 rounded-full"
              >Logo Design</span
            >
          </div>
          <h3 class="text-2xl font-bold text-dark mb-3">Aosi Core Identity</h3>
          <p class="text-gray-600 text-sm">
            Minimalist logo conceptualization building the brand's visual
            language.
          </p>
        </div>
      </div>

      <div
        class="group bg-white rounded-3xl overflow-hidden border border-gray-100 shadow-[0_4px_30px_rgba(0,0,0,0.02)] hover:shadow-[0_30px_60px_rgba(15,98,254,0.08)] transition-all duration-500 hover:-translate-y-2"
      >
        <a
          data-fslightbox="gallery"
          href={floraFlyer2.src}
          class="block aspect-[4/3] bg-gray-100 w-full relative overflow-hidden flex items-center justify-center p-6 cursor-zoom-in"
        >
          <Image
            src={floraFlyer2}
            alt="Dinujaya Flora Social Media Promotion Banner"
            class="w-full h-full object-contain transition-transform duration-700 ease-out group-hover:scale-105"
            quality="high"
          />
        </a>
        <div class="p-8 md:p-10">
          <div class="flex flex-wrap gap-2 mb-4">
            <span
              class="px-3 py-1 text-xs font-bold text-cyan-600 bg-cyan-50 rounded-full"
              >Promotion</span
            >
          </div>
          <h3 class="text-2xl font-bold text-dark mb-3">
            Dinujaya Campaign Assets
          </h3>
          <p class="text-gray-600 text-sm">
            Strategic marketing materials designed to drive customer inquiries.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-16 text-center">
      <a
        href={`${import.meta.env.BASE_URL}work`}
        class="inline-flex items-center gap-2 px-8 py-4 bg-white border border-gray-200 text-dark font-bold rounded-2xl hover:border-primary hover:text-primary transition-all duration-300 shadow-sm hover:shadow-md"
      >
        View Full Portfolio
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
        >
      </a>
    </div>
  </div>
</section>

<script
  is:inline
  src="https://cdn.jsdelivr.net/npm/fslightbox@3.4.1/index.min.js"></script>
