---
// Premium Minimalist Header (Bug Fixed & Scroll-Aware)
---
<div class="fixed top-6 left-0 w-full z-50 flex justify-center pointer-events-none px-6">
    
    <nav id="smart-header" class="pointer-events-auto w-full max-w-4xl transition-transform duration-500 ease-[cubic-bezier(0.33,1,0.68,1)] translate-y-0">
        <div class="bg-white/80 backdrop-blur-md border border-gray-100 shadow-[0_8px_30px_rgb(0,0,0,0.04)] rounded-2xl px-6 py-4 flex items-center justify-between">
            <a href="/" class="text-xl font-extrabold tracking-tighter text-dark hover:text-primary transition-colors">
                LOGIC<span class="text-primary">.</span>LANKA
            </a>
            
            <div class="hidden md:flex items-center gap-8">
                <a href="#services" class="text-sm font-semibold text-gray-500 hover:text-dark transition-colors">Capabilities</a>
                <a href="#portfolio" class="text-sm font-semibold text-gray-500 hover:text-dark transition-colors">Work</a>
                <a href="#contact" class="text-sm font-semibold text-gray-500 hover:text-dark transition-colors">Contact</a>
            </div>

            <a href="#contact" class="px-6 py-2.5 bg-dark text-white text-sm font-bold rounded-xl hover:bg-primary hover:shadow-[0_4px_20px_rgba(15,98,254,0.3)] transition-all duration-300 hover:-translate-y-0.5">
                Let's Talk
            </a>
        </div>
    </nav>
</div>

<script>
    // Smart Header Logic (The clean way)
    let lastScrollY = window.scrollY;
    const header = document.getElementById('smart-header');

    window.addEventListener('scroll', () => {
        if (!header) return;
        
        const currentScrollY = window.scrollY;
        
        if (currentScrollY > lastScrollY && currentScrollY > 100) {
            // පල්ලෙහාට යද්දී: Header එක උඩට ගිහින් හැංගෙනවා (-translate-y-32)
            header.classList.remove('translate-y-0');
            header.classList.add('-translate-y-32');
        } else {
            // උඩට එද්දී: Header එක ආපහු සාමාන්‍ය තැනට එනවා (translate-y-0)
            header.classList.remove('-translate-y-32');
            header.classList.add('translate-y-0');
        }
        
        lastScrollY = currentScrollY;
    }, { passive: true });
</script>